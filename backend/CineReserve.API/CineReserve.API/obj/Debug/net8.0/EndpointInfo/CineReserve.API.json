      "get": {
        "tags": [
          "Showtimes"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Showtimes"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Showtime"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Showtime"
              }
            },
            "application/*+json": {
