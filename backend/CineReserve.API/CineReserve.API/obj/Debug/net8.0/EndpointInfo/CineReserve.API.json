  "components": {
    "schemas": {
      "BookingRequestDto": {
        "type": "object",
        "properties": {
          "showtimeId": {
            "type": "integer",
            "format": "int32"
          },
          "seats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SeatDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Movie": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "duration": {
            "type": "integer",
            "format": "int32"
          },
          "genre": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SeatDto": {
        "type": "object",
        "properties": {
          "rowNumber": {
            "type": "string",
            "nullable": true
          },
          "seatNumber": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Showtime": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "movieId": {
            "type": "integer",
            "format": "int32"
          },
          "showDate": {
            "type": "string",
            "format": "date-time"
          },
          "showTime": {
            "type": "string",
            "format": "date-span"
          },
          "hallName": {
            "type": "string",
            "nullable": true
          },
          "movie": {
            "$ref": "#/components/schemas/Movie"
          }
        },
        "additionalProperties": false
      }
    }
  }
}